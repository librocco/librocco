---
const base = import.meta.env.BASE_URL;
---

<div class="h-px bg-base-300 w-full"></div>

<footer class="flex flex-col gap-5 bg-base-100 px-5 py-6 w-full">
  <div class="flex flex-col gap-6 md:flex-row md:items-center w-full">
    <div class="flex flex-wrap items-center gap-6">
      <a href={`${base}getting-started/introduction`} class="text-sm font-medium text-base-content hover:text-primary transition-colors">Docs</a>
      <a href={`${base}changelog`} class="text-sm font-medium text-base-content hover:text-primary transition-colors">Changelog</a>
      <a href="https://github.com/librocco" class="text-sm font-medium text-base-content hover:text-primary transition-colors">GitHub</a>
      <a href="mailto:hello@codemyriad.io" class="text-sm font-medium text-base-content hover:text-primary transition-colors">Contact us</a>
    </div>
    <span class="text-sm font-medium text-base-content/50">© 2026 Librocco</span>
  </div>
</footer>
