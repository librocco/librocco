---
import { getCollection } from 'astro:content';
import { ViewTransitions } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ChangelogEntry from '../components/ChangelogEntry.astro';
import CtaBanner from '../components/CtaBanner.astro';
import FixedBadges from '../components/FixedBadges.astro';

const rawEntries = (await getCollection('changelog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const entries = await Promise.all(
  rawEntries.map(async (entry) => {
    const { Content } = await entry.render();
    return { ...entry, Content };
  })
);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Librocco – Changelog</title>
  <meta name="description" content="What's new in Librocco — updates, improvements and fixes." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <ViewTransitions />
</head>
<body class="bg-base-100 text-base-content min-h-screen flex flex-col">

  <Nav transition:persist="site-nav" />

  <!-- Changelog entries -->
  <main class="flex flex-col items-center w-full pt-28 pb-4">
    <div class="flex flex-col w-full max-w-7xl px-5 md:px-10 lg:px-20">

      <h1 class="changelog-title text-xl md:text-2xl font-bold text-base-content mb-8">Changelog</h1>

      {entries.map((entry, i) => (
        <ChangelogEntry
          title={entry.data.title}
          date={entry.data.date}
          author={entry.data.author}
          Content={entry.Content}
          isLast={i === entries.length - 1}
          index={i}
        />
      ))}

    </div>
  </main>

  <div class="h-px bg-base-300 w-full"></div>

  <CtaBanner />

  <Footer />
  <FixedBadges />

  <script>
    function init() {
      const title = document.querySelector<HTMLElement>('.changelog-title');
      if (title) title.classList.add('in-view');

      const entries = document.querySelectorAll<HTMLElement>('.changelog-entry');
      let firstCallback = true;

      const observer = new IntersectionObserver((records) => {
        const isFirst = firstCallback;
        firstCallback = false;

        const visible = records.filter(r => r.isIntersecting);
        visible.forEach((record) => {
          const el = record.target as HTMLElement;
          const globalIndex = Number(el.dataset.index ?? 0);
          const delay = isFirst ? globalIndex * 150 : 0;
          el.style.setProperty('--entry-delay', `${delay}ms`);
          el.classList.add('in-view');
          observer.unobserve(el);
        });
      }, { threshold: 0.1 });

      entries.forEach(el => observer.observe(el));
    }

    document.addEventListener('astro:page-load', init);
  </script>

</body>
</html>

<style is:global>
  @import '../tailwind.css';

  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  .changelog-title {
    opacity: 0;
  }
  .changelog-title.in-view {
    animation: fadeSlideIn 0.5s ease both;
  }
</style>
