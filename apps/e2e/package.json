{
	"name": "@librocco/e2e",
	"version": "0.0.1",
	"scripts": {
		"build": "echo e2e has no build functionality, skipping...",
		"test:open": "node ../../scripts/run_with_vendor_source.mjs playwright test --ui",
		"test:vfs:open": "VFS_TEST=true node ../../scripts/run_with_vendor_source.mjs playwright test --ui",
		"test:vfs:run": "VFS_TEST=true node ../../scripts/run_with_vendor_source.mjs playwright test",
		"test:vfs:ci": "(cd ../web-client && rushx preview) & PREVIEW_PID=$!; CI=true VFS_TEST=true node ../../scripts/run_with_vendor_source.mjs playwright test ${PLAYWRIGHT_OPTIONS:-} \"$@\"; RESULT=$?; kill $PREVIEW_PID; exit $RESULT",
		"test:debug": "PLAYWRIGHT_HTML_OPEN=never node ../../scripts/run_with_vendor_source.mjs playwright test $1 --debug",
		"test:run": "PLAYWRIGHT_HTML_OPEN=never node ../../scripts/run_with_vendor_source.mjs playwright test",
		"test:codegen": "node ../../scripts/run_with_vendor_source.mjs playwright codegen",
		"test:ci": "CI=true node ../../scripts/run_with_vendor_source.mjs playwright test ${PLAYWRIGHT_OPTIONS:-} \"$@\"",
		"typecheck": "tsc",
		"lint": "prettier --check . && eslint .",
		"lint:strict": "prettier --check . && eslint . --max-warnings=0",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@librocco/shared": "workspace:*",
		"@playwright/test": "~1.50.0",
		"@typescript-eslint/eslint-plugin": "^8.22.0",
		"@typescript-eslint/parser": "^8.22.0",
		"@vlcn.io/crsqlite-wasm": "0.16.0-dev.20260313.f95a20ad",
		"eslint": "^8.13.0",
		"eslint-config-prettier": "^8.6.0",
		"prettier": "3.4.2",
		"typescript": "~5.9.3",
		"@types/node": "~20.4.1",
		"@internationalized/date": "~3.7.0",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "~0.6.8"
	},
	"type": "module"
}
